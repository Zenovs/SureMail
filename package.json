{
  "name": "coremail-desktop",
  "version": "2.6.0",
  "description": "CoreMail Desktop v2.6.0 - Manuelle Mail-Kategorisierung mit Absender-Lernen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "build": "npm run react-build && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.coremail.desktop",
    "productName": "CoreMail Desktop",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "extends": null,
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Network;Email",
      "synopsis": "Minimaler E-Mail-Client für Linux",
      "description": "CoreMail Desktop - Ein schlanker IMAP/SMTP E-Mail-Client mit dunklem Design",
      "maintainer": "CoreMail Team"
    },
    "appImage": {
      "artifactName": "${productName}-${version}.AppImage"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,readme,test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      },
      {
        "from": "assets/coremail-icon-256.png",
        "to": "icons/256x256.png"
      },
      {
        "from": "assets/coremail-icon-128.png",
        "to": "icons/128x128.png"
      },
      {
        "from": "assets/coremail-icon-64.png",
        "to": "icons/64x64.png"
      },
      {
        "from": "assets/coremail-icon-32.png",
        "to": "icons/32x32.png"
      }
    ]
  },
  "homepage": "./",
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-store": "^8.1.0",
    "imap-simple": "^5.1.0",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.6.6",
    "nodemailer": "^6.9.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
